# Local dev: npm run dev (or dev:local) uses this file + .env.local.
# Against a deployed API: copy .env.remote.example → .env.remote, then npm run dev:remote (see package.json).

# NamasQR API origin (no trailing slash), e.g. http://localhost:8000 — REST paths use /api/...
NEXT_PUBLIC_API_ORIGIN=http://localhost:8000

# Public URL of this Next.js app (no trailing slash). Used when generating table QR links outside the browser (optional).
# In the browser, table QR uses window.location.origin automatically.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: override socket origin (defaults to NEXT_PUBLIC_API_ORIGIN). Namespace /kitchen is appended in code.
NEXT_PUBLIC_SOCKET_ORIGIN=

# Server-only: proxy guest QR menu to GET /api/admin/menu when public menu is unavailable (see app/api/qr/menu)
MENU_PROXY_BEARER_TOKEN=

# Server-only (optional): where landing-page contact-sales leads should be posted (webhook/CRM endpoint).
# If unset, Next.js API route will try POST ${NEXT_PUBLIC_API_ORIGIN}/api/public/contact-sales.
CONTACT_SALES_WEBHOOK_URL=

# Backend (email): reset links should point at this app’s public URL, e.g. https://app.example.com/reset-password?token=...
# Frontend implements /reset-password and /forgot-password. Set on API server: FRONTEND_URL or APP_PUBLIC_URL (backend docs).

