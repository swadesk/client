# Copy to .env.remote (gitignored): cp .env.remote.example .env.remote
#
# dev:remote / build:remote load .env first, then this file (values here override).
# Put only deployed URL overrides here; keep secrets in .env / .env.local as usual.
#
# NEXT_PUBLIC_* are inlined when Next builds; use build:remote for a bundle aimed at that API.

NEXT_PUBLIC_API_ORIGIN=https://api.your-domain.com
NEXT_PUBLIC_SOCKET_ORIGIN=
NEXT_PUBLIC_APP_URL=https://app.your-domain.com

CONTACT_SALES_WEBHOOK_URL=https://api.your-domain.com
